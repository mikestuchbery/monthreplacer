<body>

<header>
  <h1>Month Replacer</h1>
  <span>// HTML email utility</span>
</header>

<div class="step-label">1 — Paste HTML</div>
<div class="card">
  <div class="card-header">
    <span class="card-label">Input HTML</span>
    <button class="btn-outline" style="font-size:0.65rem;padding:5px 12px;" onclick="analyse()">⟳ Scan</button>
  </div>
  <textarea id="input" placeholder="Paste your HTML here — months detected automatically…" oninput="analyse()" onpaste="setTimeout(analyse,50)"></textarea>
</div>

<div id="step2" style="display:none;">
  <div class="step-label">2 — Months found — select replacement for each</div>
  <div id="pickers"></div>
  <div class="fire-wrap">
    <button class="btn-fire" onclick="doReplace()">⚡ Replace All &amp; Generate Output</button>
  </div>
</div>

<div id="no-detection" class="none-found" style="display:none;">No months detected in pasted HTML.</div>

<div id="step3" style="display:none;">
  <div class="step-label">3 — Output</div>
  <div class="card">
    <div class="card-header">
      <span class="card-label">Updated HTML</span>
      <div style="display:flex;align-items:center;gap:10px;">
        <span class="copy-success" id="copy-ok">✓ Copied</span>
        <button class="btn-outline" onclick="copyOutput()">Copy</button>
      </div>
    </div>
    <div id="verify-msg" style="display:none;"></div>
    <textarea id="output" readonly></textarea>
  </div>
</div>

<script>
const MONTHS = {
