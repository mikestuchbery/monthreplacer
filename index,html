  hr_gen: ["siječnja","veljače","ožujka","travnja","svibnja","lipnja","srpnja","kolovoza","rujna","listopada","studenog","prosinca"],
  hr_loc: ["siječnju","veljači","ožujku","travnju","svibnju","lipnju","srpnju","kolovozu","rujnu","listopadu","studenom","prosincu"],
  sr: ["januar","februar","mart","april","maj","jun","jul","avgust","septembar","oktobar","novembar","decembar"],
  bg: ["януари","февруари","март","април","май","юни","юли","август","септември","октомври","ноември","декември"],
