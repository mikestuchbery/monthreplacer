  uk: ["січень","лютий","березень","квітень","травень","червень","липень","серпень","вересень","жовтень","листопад","грудень"],
  lt: ["sausis","vasaris","kovas","balandis","gegužė","birželis","liepa","rugpjūtis","rugsėjis","spalis","lapkritis","gruodis"],
  lv: ["janvāris","februāris","marts","aprīlis","maijs","jūnijs","jūlijs","augusts","septembris","oktobris","novembris","decembris"],
  et: ["jaanuar","veebruar","märts","aprill","mai","juuni","juuli","august","september","oktoober","november","detsember"],
  et_gen: ["jaanuari","veebruari","märtsi","aprilli","mai","juuni","juuli","augusti","septembri","oktoobri","novembri","detsembri"],
  et_ine: ["jaanuaris","veebruaris","märtsis","aprillis","mais","juunis","juulis","augustis","septembris","oktoobris","novembris","detsembris"],
  sl: ["januar","februar","marec","april","maj","junij","julij","avgust","september","oktober","november","december"],
  sl_gen: ["januarja","februarja","marca","aprila","maja","junija","julija","avgusta","septembra","oktobra","novembra","decembra"],
  ca: ["gener","febrer","març","abril","maig","juny","juliol","agost","setembre","octubre","novembre","desembre"],
  sq: ["janar","shkurt","mars","prill","maj","qershor","korrik","gusht","shtator","tetor","nëntor","dhjetor"],
  bs: ["januar","februar","mart","april","maj","juni","juli","august","septembar","oktobar","novembar","decembar"],
  mk: ["јануари","февруари","март","април","мај","јуни","јули","август","септември","октомври","ноември","декември"],
  is: ["janúar","febrúar","mars","apríl","maí","júní","júlí","ágúst","september","október","nóvember","desember"],
  mt: ["Jannar","Frar","Marzu","April","Mejju","Ġunju","Lulju","Awwissu","Settembru","Ottubru","Novembru","Diċembru"],
  ga: ["Eanáir","Feabhra","Márta","Aibreán","Bealtaine","Meitheamh","Iúil","Lúnasa","Meán Fómhair","Deireadh Fómhair","Samhain","Nollaig"],
  cy: ["Ionawr","Chwefror","Mawrth","Ebrill","Mai","Mehefin","Gorffennaf","Awst","Medi","Hydref","Tachwedd","Rhagfyr"],
  lb: ["Januar","Februar","Mäerz","Abrëll","Mee","Juni","Juli","August","September","Oktober","November","Dezember"],
};

const LANG_CANONICAL = { hr_gen: 'hr', hr_loc: 'hr', cs_gen: 'cs', cs_loc: 'cs', sk_gen: 'sk', sk_loc: 'sk', sl_gen: 'sl', pl_gen: 'pl', pl_loc: 'pl', et_gen: 'et', et_ine: 'et' };

const LANG_NAMES = {
  en:"English", de:"Deutsch", es:"Español", fr:"Français", it:"Italiano",
  nl:"Nederlands", pt:"Português", pl:"Polski", sv:"Svenska", da:"Dansk",
  no:"Norsk", fi:"Suomi", cs:"Čeština", sk:"Slovenčina", hu:"Magyar",
  ro:"Română", hr:"Hrvatski", hr_gen:"Hrvatski", hr_loc:"Hrvatski", cs_gen:"Čeština", cs_loc:"Čeština", sk_gen:"Slovenčina", sk_loc:"Slovenčina", sl_gen:"Slovenščina", pl_gen:"Polski", pl_loc:"Polski", sr:"Srpski", bg:"Български",
  el:"Ελληνικά", tr:"Türkçe", ru:"Русский", uk:"Українська", lt:"Lietuvių",
  lv:"Latviešu", et:"Eesti", sl:"Slovenščina", ca:"Català",
  sq:"Shqip", bs:"Bosanski", mk:"Македонски", is:"Íslenska",
  mt:"Malti", ga:"Gaeilge", cy:"Cymraeg", lb:"Lëtzebuergesch"
};

const LANG_OPTIONS = [
  ['en','English'],['de','Deutsch'],['es','Español'],['fr','Français'],
  ['it','Italiano'],['nl','Nederlands'],['pt','Português'],['pl','Polski'],
  ['sv','Svenska'],['da','Dansk'],['no','Norsk'],['fi','Suomi'],
  ['cs','Čeština'],['sk','Slovenčina'],['hu','Magyar'],['ro','Română'],
  ['hr','Hrvatski'],['sr','Srpski'],['bg','Български'],['el','Ελληνικά'],
  ['tr','Türkçe'],['ru','Русский'],['uk','Українська'],['lt','Lietuvių'],
  ['lv','Latviešu'],['et','Eesti'],['sl','Slovenščina'],['ca','Català'],
  ['sq','Shqip'],['bs','Bosanski'],['mk','Македонски'],['is','Íslenska'],
  ['mt','Malti'],['ga','Gaeilge'],['cy','Cymraeg'],['lb','Lëtzebuergesch'],
];

// Matches any letter character across all European scripts
// Using explicit Unicode code point ranges to ensure consistent JS behaviour
function isLetter(ch) {
  if (!ch) return false;
  const c = ch.charCodeAt(0);
  return (
    (c >= 0x41  && c <= 0x5A) || // A-Z
    (c >= 0x61  && c <= 0x7A) || // a-z
    (c >= 0xC0  && c <= 0xD6) || // À-Ö
    (c >= 0xD8  && c <= 0xF6) || // Ø-ö
    (c >= 0xF8  && c <= 0x2AF) || // ø-ɏ (Latin Extended)
    (c >= 0x370 && c <= 0x3FF) || // Greek
    (c >= 0x400 && c <= 0x4FF) || // Cyrillic
    (c >= 0x1E00 && c <= 0x1EFF)  // Latin Extended Additional (Welsh, Vietnamese etc)
  );
}

function findInText(text, name) {
  // Skip very short names (< 3 chars) to avoid false positives
  if (name.length < 3) return { count: 0, firstMatch: null };
  const lower = text.toLowerCase();
  const target = name.toLowerCase();
  let count = 0, firstMatch = null, pos = 0;
  while (true) {
    const idx = lower.indexOf(target, pos);
    if (idx === -1) break;
    const b = text[idx - 1], a = text[idx + target.length];
    if (!isLetter(b) && !isLetter(a)) {
      count++;
      if (!firstMatch) firstMatch = text.slice(idx, idx + target.length);
    }
    pos = idx + 1;
  }
  return { count, firstMatch };
}

function detectMonths(text) {
  // Group all found forms (nominative + genitive variants) by canonical lang + month index
  const groups = {};
  for (const [lang, months] of Object.entries(MONTHS)) {
    const canon = LANG_CANONICAL[lang] || lang;
    months.forEach((name, monthIndex) => {
      const { count, firstMatch } = findInText(text, name);
      if (count > 0) {
        const key = monthIndex + '_' + canon;
        if (!groups[key]) {
          groups[key] = { allNames: [], canonLang: canon, lang: canon, monthIndex, count: 0, display: null };
        }
        groups[key].allNames.push(name);
        groups[key].count += count;
        if (!groups[key].display) groups[key].display = firstMatch;
      }
    });
  }
  return Object.values(groups);
}

let detectedMatches = [];
let selections = [];

function analyse() {
  const text = document.getElementById('input').value.trim();
  selections = [];
  document.getElementById('step2').style.display = 'none';
  document.getElementById('no-detection').style.display = 'none';
  document.getElementById('step3').style.display = 'none';
  if (!text) return;

  detectedMatches = detectMonths(text);

  if (!detectedMatches.length) {
    document.getElementById('no-detection').style.display = 'block';
    return;
  }

  selections = detectedMatches.map(() => ({ targetLang: null, targetMonthIndex: null }));
  renderPickers();
  document.getElementById('step2').style.display = 'block';
}

function renderPickers() {
  const container = document.getElementById('pickers');
  container.innerHTML = '';
  detectedMatches.forEach((m, i) => {
    const defaultLang = m.canonLang;
    const langName = LANG_NAMES[m.lang] || m.lang;
    const opts = LANG_OPTIONS.map(([code, label]) =>
      `<option value="${code}"${code === defaultLang ? ' selected' : ''}>${label}</option>`
    ).join('');

    const div = document.createElement('div');
    div.className = 'month-picker';
    div.innerHTML = `
      <div class="picker-header">
        <span class="picker-found">
          Found: <strong>${m.display}</strong>
          <span class="plang">${langName}</span>
          <span class="pcount">${m.count} occurrence${m.count !== 1 ? 's' : ''}</span>
        </span>
        <div style="display:flex;align-items:center;gap:6px;">
          <span style="font-family:'JetBrains Mono',monospace;font-size:0.63rem;color:var(--muted);">Replace in:</span>
          <select class="lang-sel" id="langsel_${i}" onchange="onLangChange(${i})">${opts}</select>
        </div>
      </div>
      <div class="month-grid" id="grid_${i}"></div>
    `;
    container.appendChild(div);
    buildGrid(i, defaultLang);
  });
}

function buildGrid(pickerIndex, lang) {
  const months = MONTHS[lang] || MONTHS['en'];
  const isEn = lang === 'en';
  const sel = selections[pickerIndex];
  document.getElementById('grid_' + pickerIndex).innerHTML = months.map((m, i) =>
    `<button class="month-btn${sel && sel.targetLang === lang && sel.targetMonthIndex === i ? ' selected' : ''}"
      onclick="selectMonth(${pickerIndex},${i})">
      ${m}${!isEn ? `<span class="en">${MONTHS['en'][i]}</span>` : ''}
    </button>`
  ).join('');
}

function onLangChange(i) {
  const lang = document.getElementById('langsel_' + i).value;
  selections[i] = { targetLang: lang, targetMonthIndex: null };
  buildGrid(i, lang);
}

function selectMonth(pickerIndex, monthIndex) {
  const lang = document.getElementById('langsel_' + pickerIndex).value;
  selections[pickerIndex] = { targetLang: lang, targetMonthIndex: monthIndex };
  buildGrid(pickerIndex, lang);
}

function doReplace() {
  const missing = selections.findIndex(s => s.targetMonthIndex === null);
  if (missing !== -1) {
    alert('Please select a replacement month for all detected entries (entry ' + (missing + 1) + ' is unselected).');
    return;
  }

  let text = document.getElementById('input').value;
  detectedMatches.forEach((m, i) => {
    const { targetLang, targetMonthIndex } = selections[i];
    const replacement = MONTHS[targetLang][targetMonthIndex];
    (m.allNames || [m.name]).forEach(name => {
      text = replaceAll(text, name, replacement);
    });
  });

  document.getElementById('output').value = text;
  document.getElementById('step3').style.display = 'block';

  const lines = [], verifyEl = document.getElementById('verify-msg');
  let allOk = true;
  detectedMatches.forEach((m, i) => {
    const { targetLang, targetMonthIndex } = selections[i];
    const expected = MONTHS[targetLang][targetMonthIndex];
    const { count } = findInText(text, expected);
    if (count > 0) {
      lines.push('✓ "' + expected + '" — ' + count + ' occurrence' + (count !== 1 ? 's' : ''));
    } else {
      lines.push('✗ "' + expected + '" not found — replacement may have failed');
      allOk = false;
    }
  });
  verifyEl.className = allOk ? 'verify-ok' : 'verify-fail';
  verifyEl.innerHTML = lines.join('<br>');
  verifyEl.style.display = 'block';
  document.getElementById('step3').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function replaceAll(text, searchName, replacement) {
  const lower = text.toLowerCase(), target = searchName.toLowerCase();
  let result = '', pos = 0;
  while (true) {
    const idx = lower.indexOf(target, pos);
    if (idx === -1) { result += text.slice(pos); break; }
    const b = text[idx - 1], a = text[idx + target.length];
    if (!isLetter(b) && !isLetter(a)) {
      result += text.slice(pos, idx) + matchCase(text.slice(idx, idx + target.length), replacement);
    } else {
      result += text.slice(pos, idx + target.length);
    }
    pos = idx + target.length;
  }
  return result;
}

function matchCase(orig, rep) {
  if (orig === orig.toUpperCase() && orig !== orig.toLowerCase()) return rep.toUpperCase();
  if (orig[0] === orig[0].toUpperCase()) return rep[0].toUpperCase() + rep.slice(1);
  return rep.toLowerCase();
}

function copyOutput() {
  const ta = document.getElementById('output');
  ta.select(); ta.setSelectionRange(0, 99999);
  let ok = false;
  try { ok = document.execCommand('copy'); } catch(e) {}
  if (!ok && navigator.clipboard) navigator.clipboard.writeText(ta.value).catch(() => {});
  window.getSelection && window.getSelection().removeAllRanges();
  const b = document.getElementById('copy-ok');
  b.classList.add('show');
  setTimeout(() => b.classList.remove('show'), 2000);
}
