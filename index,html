  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg); color: var(--text);
    min-height: 100vh; display: flex; flex-direction: column;
    align-items: center; padding: 40px 20px 80px;
  }

  header { width: 100%; max-width: 820px; margin-bottom: 32px; display: flex; align-items: baseline; gap: 14px; }
  header h1 { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); }
